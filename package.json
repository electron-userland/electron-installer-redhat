{
  "name": "electron-installer-redhat",
  "description": "Create a Red Hat package for your Electron app.",
  "version": "3.4.0",
  "license": "MIT",
  "author": {
    "name": "Daniel Perez Alvarez",
    "email": "unindented@gmail.com",
    "url": "http://unindented.org/"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/electron-userland/electron-installer-redhat.git"
  },
  "keywords": [
    "electron",
    "redhat"
  ],
  "os": [
    "darwin",
    "linux"
  ],
  "engines": {
    "node": ">= 22.12.0"
  },
  "packageManager": "yarn@4.10.3+sha512.c38cafb5c7bb273f3926d04e55e1d8c9dfa7d9c3ea1f36a4868fa028b9e5f72298f0b7f401ad5eb921749eb012eb1c3bb74bf7503df3ee43fd600d14a018266f",
  "type": "module",
  "exports": "./src/installer.js",
  "bin": "src/cli.js",
  "scripts": {
    "coverage": "node --test --experimental-test-coverage test/*.js",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "prepare": "husky install",
    "spec": "node --test test/*.js",
    "test": "yarn lint && yarn spec"
  },
  "dependencies": {
    "@malept/cross-spawn-promise": "^2.0.0",
    "debug": "^4.1.1",
    "electron-installer-common": "^0.10.3",
    "which": "^5.0.0",
    "word-wrap": "^1.2.4",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "chai": "^6.2.0",
    "husky": "^6.0.0",
    "lint-staged": "^10.2.7",
    "oxlint": "^1.59.0",
    "promise-retry": "^2.0.1",
    "sinon": "^11.1.0",
    "tmp-promise": "^3.0.2"
  },
  "lint-staged": {
    "*.js": "oxlint --fix"
  }
}
